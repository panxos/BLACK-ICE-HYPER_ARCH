#!/bin/bash
# updates_status — checkupdates (oficial) + paru -Qu (AUR)
set -uo pipefail

OFFICIAL=0
AUR=0

# Oficial: checkupdates es seguro (no bloquea lockfile de pacman)
if command -v checkupdates &>/dev/null; then
    OFFICIAL=$(checkupdates 2>/dev/null | wc -l)
elif command -v pacman &>/dev/null; then
    OFFICIAL=$(pacman -Qu 2>/dev/null | wc -l)
fi

# AUR: solo si paru disponible
if command -v paru &>/dev/null; then
    AUR=$(paru -Qu --aur 2>/dev/null | grep -v '\-git ' | wc -l || echo 0)
fi

COUNT=$(( OFFICIAL + AUR ))

if [[ "$COUNT" -gt 0 ]]; then
    PKGS=""
    command -v checkupdates &>/dev/null && PKGS=$(checkupdates 2>/dev/null | head -5 | awk '{print $1}' | tr '\n' ',' | sed 's/,$//')
    [[ "$COUNT" -gt 5 ]] && PKGS="${PKGS}... (+$(( COUNT - 5 )) más)"
    printf '{"text":"󰮯 %s","class":"updates","tooltip":"%s pendientes:\\n%s"}\n' "$COUNT" "$COUNT" "$PKGS"
else
    echo '{"text":"󰮯 0","class":"cleaned","tooltip":"Sistema actualizado"}'
fi
