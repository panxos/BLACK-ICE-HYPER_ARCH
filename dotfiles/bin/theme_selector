#!/bin/bash
# theme_selector — BLACK-ICE ARCH
# Selector dinámico de temas Waybar + wallpaper + border color
# Temas gh0stzk-inspired: credits https://github.com/gh0stzk/dotfiles

THEMES_DIR="$HOME/.config/waybar/themes"
W_DIR="$HOME/.config/waybar"
WALL_DIR="$HOME/Pictures/wallpapers"
CACHE_WALL="$HOME/.cache/current_wallpaper"
CACHE_THEME="$HOME/.cache/current_theme"
FF_DIR="$HOME/.config/fastfetch"

# ---------------------------------------------------------------------------
# Colores de borde Hyprland por tema (col.active_border)
# formato: "0xeeACCENT1 0xeeACCENT2"
# ---------------------------------------------------------------------------
declare -A BORDER_COLORS=(
    # --- Original Egyptian God Themes ---
    ["Horus-Cyber"]="0xee00f3ff 0xeebd93f9"
    ["Ra-Solar"]="0xeeffaa00 0xee552200"
    ["Isis-Magic"]="0xeeff00ff 0xee330033"
    ["Anubis-Death"]="0xee44ff00 0xee002200"
    ["s4vitar-darkness"]="0xee6a0dad 0xee0d0d0d"
    ["Matrix-Hacker"]="0xee00ff00 0xee001100"
    # --- gh0stzk inspired (original) ---
    ["Jan-CyberPunk"]="0xee27fbfe 0xeefb007a"
    ["Emilia-TokyoNight"]="0xee7aa2f7 0xeebb9af7"
    ["Marisol-Dracula"]="0xeebd93f9 0xeeff79c6"
    ["Melissa-Nord"]="0xee81a1c1 0xee88c0d0"
    # --- gh0stzk inspired (new) ---
    ["Karla-ZombieNight"]="0xee8897F4 0xeeadd7ff"
    ["Pamela-Lovelace"]="0xeeb4dafe 0xeeff85cb"
    ["Zombie-Decay"]="0xee89b4fa 0xeecba6f7"
    ["Brenda-Everforest"]="0xeea7c080 0xee7fbbb3"
    ["Daniela-Catppuccin"]="0xee89b4fa 0xeecba6f7"
    ["H4k3r-HTB"]="0xee9fef00 0xee00ff7f"
    ["Silvia-Gruvbox"]="0xeefe8019 0xeeb8bb26"
    ["Varinka-Mono"]="0xeeadb5bd 0xee6c757d"
    ["Yael-OxoCarbon"]="0xee42BE65 0xee78a9ff"
    ["Janis-CyberMagenta"]="0xeeff007c 0xee00e5ff"
    ["Isabel-Frappe"]="0xee8caaee 0xeeca9ee6"
)

# ---------------------------------------------------------------------------
# Wallpapers por tema (nombre del archivo en $WALL_DIR)
# Si no existe el archivo, awww mantiene el wallpaper actual
# ---------------------------------------------------------------------------
declare -A WALLPAPERS=(
    # --- Original themes ---
    ["Horus-Cyber"]="HORUS-CYBER.jpg"
    ["Ra-Solar"]="RA-SOLAR.jpg"
    ["Isis-Magic"]="ISIS-MAGIC.jpg"
    ["Anubis-Death"]="ANUBIS-DEATH.jpg"
    ["s4vitar-darkness"]="ARCH-CYBERPUNK.jpg"
    ["Matrix-Hacker"]="cyber.jpg"
    # --- gh0stzk-inspired: descargar con ~/.config/bin/gh0stzk-walls ---
    ["Jan-CyberPunk"]="jan-cyberpunk-01.webp"
    ["Emilia-TokyoNight"]="emilia-tokyonight-01.webp"
    ["Marisol-Dracula"]="marisol-dracula-01.webp"
    ["Melissa-Nord"]="melissa-nord-01.webp"
    ["Karla-ZombieNight"]="karla-01.webp"
    ["Pamela-Lovelace"]="pamela-01.webp"
    ["Zombie-Decay"]="zombie-01.webp"
    ["Brenda-Everforest"]="brenda-01.webp"
    ["Daniela-Catppuccin"]="daniela-01.webp"
    ["H4k3r-HTB"]="h4k3r-01.webp"
    ["Silvia-Gruvbox"]="silvia-01.webp"
    ["Varinka-Mono"]="varinka-01.webp"
    ["Yael-OxoCarbon"]="yael-01.webp"
    ["Janis-CyberMagenta"]="janis-01.webp"
    ["Isabel-Frappe"]="isabel-01.webp"
)

# ---------------------------------------------------------------------------
# Auto-detectar temas disponibles desde el directorio
# (cualquier carpeta con config.jsonc + style.css)
# ---------------------------------------------------------------------------
mapfile -t AVAILABLE_THEMES < <(
    find "$THEMES_DIR" -maxdepth 1 -mindepth 1 -type d \
        -exec sh -c 'test -f "$1/config.jsonc" && test -f "$1/style.css"' _ {} \; \
        -print | xargs -I{} basename {} | sort
)

if [ ${#AVAILABLE_THEMES[@]} -eq 0 ]; then
    notify-send "BLACK-ICE" "No se encontraron temas en $THEMES_DIR" --urgency=critical
    exit 1
fi

# ---------------------------------------------------------------------------
# Mostrar selector (wofi)
# ---------------------------------------------------------------------------
CURRENT_THEME=$(cat "$CACHE_THEME" 2>/dev/null || echo "")

SELECTION=$(printf '%s\n' "${AVAILABLE_THEMES[@]}" | \
    wofi --dmenu \
         --prompt "󰉼  Theme:" \
         --width 300 \
         --height 400 \
         --cache-file /dev/null \
         --no-actions \
         --insensitive)

[ -z "$SELECTION" ] && exit 0
[ "$SELECTION" == "$CURRENT_THEME" ] && {
    notify-send "BLACK-ICE" "Tema '$SELECTION' ya está activo"
    exit 0
}

echo "$SELECTION" > "$CACHE_THEME"

# ---------------------------------------------------------------------------
# Aplicar config + style via symlinks
# ---------------------------------------------------------------------------
rm -f "$W_DIR/config" "$W_DIR/config.jsonc" "$W_DIR/style.css"
ln -sf "$THEMES_DIR/$SELECTION/config.jsonc" "$W_DIR/config"
ln -sf "$THEMES_DIR/$SELECTION/config.jsonc" "$W_DIR/config.jsonc"
ln -sf "$THEMES_DIR/$SELECTION/style.css"    "$W_DIR/style.css"

# ---------------------------------------------------------------------------
# Wallpaper
# ---------------------------------------------------------------------------
WALL_FILE="${WALLPAPERS[$SELECTION]:-}"
WALL_APPLIED=false

# 1. Wallpaper específico del tema en $WALL_DIR
if [ -n "$WALL_FILE" ] && [ -f "$WALL_DIR/$WALL_FILE" ]; then
    echo "$WALL_DIR/$WALL_FILE" > "$CACHE_WALL"
    awww img "$WALL_DIR/$WALL_FILE" --transition-type grow --transition-duration 1
    WALL_APPLIED=true
fi

# 2. Estructura gh0stzk-walls descargada
if ! $WALL_APPLIED && [ -f "$WALL_DIR/gh0stzk/$SELECTION/wall-01.webp" ]; then
    WALL="$WALL_DIR/gh0stzk/$SELECTION/wall-01.webp"
    echo "$WALL" > "$CACHE_WALL"
    awww img "$WALL" --transition-type grow --transition-duration 1
    WALL_APPLIED=true
fi

# 3. Fallback: wallpaper aleatorio disponible
if ! $WALL_APPLIED; then
    RANDOM_WALL=$(find "$WALL_DIR" -maxdepth 2 \
        \( -name "*.jpg" -o -name "*.png" -o -name "*.webp" \) 2>/dev/null | shuf -n 1)
    [ -n "$RANDOM_WALL" ] && awww img "$RANDOM_WALL" --transition-type grow --transition-duration 1
fi

# ---------------------------------------------------------------------------
# Border color Hyprland
# ---------------------------------------------------------------------------
BORDER="${BORDER_COLORS[$SELECTION]:-"0xee00f3ff 0xee6800d2"}"
hyprctl keyword general:col.active_border "$BORDER 45deg" 2>/dev/null

# ---------------------------------------------------------------------------
# Fastfetch logo aleatorio
# ---------------------------------------------------------------------------
RANDOM_LOGO=$(find "$FF_DIR/logos" -name "*.png" 2>/dev/null | shuf -n 1)
[ -f "$RANDOM_LOGO" ] && cp "$RANDOM_LOGO" "$FF_DIR/current_logo.png"

# ---------------------------------------------------------------------------
# Reiniciar Waybar (graceful kill + wait loop)
# ---------------------------------------------------------------------------
pkill waybar 2>/dev/null
# Wait for waybar to actually exit (max 2 seconds)
for _i in 1 2 3 4; do
    pgrep -x waybar > /dev/null || break
    sleep 0.5
done
waybar &>/dev/null &
disown

notify-send "BLACK-ICE" "Theme Active: $SELECTION"
