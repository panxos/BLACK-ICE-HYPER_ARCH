#!/bin/bash
# vpn_status - HTB cube icon (nf-md-cube ůįÜ•)
IFACE=$(ip -o -4 addr show | awk '{print $2}' | grep -E 'tun0|wg0|utun|cscotun' | head -n 1)

if [ -n "$IFACE" ]; then
    IP=$(ip -o -4 addr show "$IFACE" | awk '{print $4}' | cut -d/ -f1)
    echo "{\"text\": \"ůįÜ• $IP\", \"class\": \"connected\", \"tooltip\": \"VPN: $IFACE ($IP)\"}"
else
    echo "{\"text\": \"ůįÜ• OFF\", \"class\": \"disconnected\", \"tooltip\": \"No VPN Active\"}"
fi
