#!/bin/bash
# docker_status (Enhanced for Waybar)

if command -v docker &>/dev/null; then
    running=$(docker ps --format '{{.Names}} ({{.Image}})' 2>/dev/null)
    count=$(echo "$running" | grep -v "^$" | wc -l)
    
    if [ "$count" -gt 0 ]; then
        tooltip="<b>🐳 Running Containers: $count</b>\n\n$running"
        echo "{\"text\": \"  $count\", \"class\": \"active\", \"tooltip\": \"$tooltip\"}"
    else
        echo "{\"text\": \"  0\", \"class\": \"inactive\", \"tooltip\": \"Docker Daemon Active\nNo containers running\"}"
    fi
else
    echo "{\"text\": \"\", \"class\": \"missing\", \"tooltip\": \"Docker not installed\"}"
fi
