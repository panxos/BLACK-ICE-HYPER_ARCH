#!/usr/bin/env python3
# cheatsheet — BLACK-ICE ARCH
# Overlay GTK3 — 3 columnas, estilo gh0stzk-inspired
# Tecla: Win+I  |  Cierra: Esc / Enter / clic fuera

import gi
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk

# ── Datos ─────────────────────────────────────────────────────────────────────
# Cada sección: { title, color (hex fondo header), binds: [(accion, key), ...] }

COLUMNS = [
    # ── Columna 1: Ventanas / Workspaces / Navegación ─────────────────────────
