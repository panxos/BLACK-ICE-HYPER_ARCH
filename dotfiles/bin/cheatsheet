CSS = """
* { font-family: "JetBrainsMono Nerd Font", "Noto Sans", monospace; }

window {
    background: rgba(10, 14, 20, 0.97);
    border: 1px solid rgba(0, 243, 255, 0.25);
    border-radius: 12px;
}

#header {
    padding: 16px 24px 8px 24px;
    border-bottom: 1px solid rgba(0, 243, 255, 0.15);
}

#title {
    font-size: 18px;
    font-weight: bold;
    color: #00f3ff;
    letter-spacing: 2px;
}

#subtitle {
    font-size: 11px;
    color: rgba(0, 243, 255, 0.5);
    margin-top: 2px;
}

#lang-btn {
    background: rgba(0, 243, 255, 0.08);
    border: 1px solid rgba(0, 243, 255, 0.3);
    border-radius: 6px;
    color: #00f3ff;
    font-size: 11px;
    padding: 4px 12px;
    min-width: 0;
}

#lang-btn:hover {
    background: rgba(0, 243, 255, 0.18);
}

#scroll {
    padding: 12px 8px;
}

.section-title {
    font-size: 12px;
    font-weight: bold;
    color: #bd93f9;
    letter-spacing: 1px;
    padding: 8px 16px 4px 16px;
    text-transform: uppercase;
}

.bind-row {
    padding: 3px 16px;
    border-radius: 4px;
}

.bind-row:hover {
    background: rgba(0, 243, 255, 0.06);
}

.key-label {
    font-size: 11px;
    font-weight: bold;
    color: #00f3ff;
    min-width: 180px;
}

.action-label {
    font-size: 11px;
    color: #a0b8c8;
}

#footer {
    padding: 8px 24px 12px 24px;
    border-top: 1px solid rgba(0, 243, 255, 0.1);
}

#footer-label {
    font-size: 10px;
    color: rgba(160, 184, 200, 0.4);
}
"""


class CheatSheet(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.lang = "es"

        # Window setup
        self.set_title("BLACK-ICE Cheat Sheet")
        self.set_decorated(False)
        self.set_keep_above(True)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_default_size(620, 700)
        self.set_app_paintable(True)

        # Transparent background
        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual:
            self.set_visual(visual)

        # CSS
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS.encode())
        Gtk.StyleContext.add_provider_for_screen(
            screen, provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        # Key handler — Esc closes
        self.connect("key-press-event", self._on_key)
        self.connect("delete-event", Gtk.main_quit)

        self._build_ui()
        self.show_all()

    def _build_ui(self):
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        root.set_name("root")
        self.add(root)

        # --- Header ---
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        header.set_name("header")

        title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.title_label = Gtk.Label(label="󰒋  BLACK-ICE CHEAT SHEET")
        self.title_label.set_name("title")
        self.title_label.set_halign(Gtk.Align.START)
        self.subtitle_label = Gtk.Label(label="BLACK-ICE ARCH — Hyprland Keybindings")
        self.subtitle_label.set_name("subtitle")
        self.subtitle_label.set_halign(Gtk.Align.START)
        title_box.pack_start(self.title_label, False, False, 0)
        title_box.pack_start(self.subtitle_label, False, False, 0)

        self.lang_btn = Gtk.Button(label="EN")
        self.lang_btn.set_name("lang-btn")
        self.lang_btn.set_valign(Gtk.Align.CENTER)
        self.lang_btn.connect("clicked", self._toggle_lang)

        header.pack_start(title_box, True, True, 0)
        header.pack_end(self.lang_btn, False, False, 0)
        root.pack_start(header, False, False, 0)

        # --- Scrollable content ---
        scroll = Gtk.ScrolledWindow()
        scroll.set_name("scroll")
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.set_vexpand(True)

        self.content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self._populate_content()
        scroll.add(self.content_box)
        root.pack_start(scroll, True, True, 0)

        # --- Footer ---
        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        footer.set_name("footer")
        footer_label = Gtk.Label(label="Esc · Enter · clic afuera → cerrar  |  BLACK-ICE ARCH by P4nx0z")
        footer_label.set_name("footer-label")
        footer.pack_start(footer_label, True, True, 0)
        root.pack_start(footer, False, False, 0)

    def _populate_content(self):
        # Clear
        for child in self.content_box.get_children():
            self.content_box.remove(child)

        lang = self.lang
        for section in KEYBINDS["sections"]:
            icon = section["icon"]
            title = section[f"title_{lang}"]

            # Section header
            sec_label = Gtk.Label(label=f"{icon}  {title.upper()}")
            sec_label.get_style_context().add_class("section-title")
            sec_label.set_halign(Gtk.Align.START)
            self.content_box.pack_start(sec_label, False, False, 0)

            # Bind rows
            for bind in section["binds"]:
                key = bind[0] if lang == "es" else bind[1]
                action = bind[2] if lang == "es" else bind[3]

                row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
                row.get_style_context().add_class("bind-row")

                key_lbl = Gtk.Label(label=key)
                key_lbl.get_style_context().add_class("key-label")
                key_lbl.set_halign(Gtk.Align.START)
                key_lbl.set_xalign(0)

                sep = Gtk.Label(label="→")
                sep.get_style_context().add_class("action-label")

                act_lbl = Gtk.Label(label=action)
                act_lbl.get_style_context().add_class("action-label")
                act_lbl.set_halign(Gtk.Align.START)
                act_lbl.set_xalign(0)

                row.pack_start(key_lbl, False, False, 0)
                row.pack_start(sep, False, False, 0)
                row.pack_start(act_lbl, True, True, 0)
                self.content_box.pack_start(row, False, False, 0)

        self.content_box.show_all()

    def _toggle_lang(self, _btn):
        self.lang = "en" if self.lang == "es" else "es"
        self.lang_btn.set_label("ES" if self.lang == "en" else "EN")
        self._populate_content()

    def _on_key(self, _widget, event):
        key = event.keyval
        if key in (Gdk.KEY_Escape, Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            Gtk.main_quit()


if __name__ == "__main__":
    CheatSheet()
    Gtk.main()
