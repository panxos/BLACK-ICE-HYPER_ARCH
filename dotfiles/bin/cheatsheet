# ── CSS ────────────────────────────────────────────────────────────────────────
CSS = """
* {
    font-family: "JetBrainsMono Nerd Font", "JetBrains Mono", monospace;
}

window {
    background-color: rgba(13, 17, 23, 0.97);
}

#root {
    background-color: transparent;
}

#title {
    font-size: 58px;
    font-weight: bold;
    letter-spacing: 12px;
    color: #bd93f9;
    padding: 28px 0 0 0;
}

#subtitle {
    font-size: 12px;
    color: #6272a4;
    letter-spacing: 2px;
    padding: 2px 0 22px 0;
}

#divider {
    background-color: rgba(98, 114, 164, 0.35);
    min-height: 1px;
    margin: 0 40px 18px 40px;
}

#columns {
    padding: 0 28px 28px 28px;
}

.col {
    padding: 0 10px;
}

.sec-header {
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 3px 12px;
    border-radius: 2px;
    margin: 12px 0 5px 0;
}

.bind-action {
    font-size: 11px;
    color: #cdd6f4;
    padding: 1px 0;
}

.bind-key {
    font-size: 10px;
    color: #6272a4;
    padding: 1px 0;
}
"""


class CheatSheet(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)

        self.set_title("BLACK-ICE Cheat Sheet")
        self.set_decorated(False)
        self.set_keep_above(True)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_app_paintable(True)
        self.fullscreen()

        # Transparencia RGBA
        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual:
            self.set_visual(visual)

        # CSS
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS.encode())
        Gtk.StyleContext.add_provider_for_screen(
            screen, provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        # Eventos de teclado
        self.connect("key-press-event", self._on_key)
        self.connect("button-press-event", self._on_click)
        self.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)

        self._build_ui()
        self.show_all()

    # ── Cierre ────────────────────────────────────────────────────────────────
    def _on_key(self, _w, event):
        if event.keyval in (Gdk.KEY_Escape, Gdk.KEY_Return, Gdk.KEY_i,
                            Gdk.KEY_q, Gdk.KEY_F1):
            Gtk.main_quit()

    def _on_click(self, _w, _e):
        Gtk.main_quit()

    # ── Construcción UI ───────────────────────────────────────────────────────
    def _build_ui(self):
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        root.set_name("root")
        self.add(root)

        # ── Título ────────────────────────────────────────────────────────────
        title = Gtk.Label()
        title.set_name("title")
        title.set_markup('<span foreground="#bd93f9">CHEAT SHEET</span>')
        title.set_halign(Gtk.Align.CENTER)
        root.pack_start(title, False, False, 0)

        subtitle = Gtk.Label(label="( Presiona Esc · Enter · I · Q · F1 para cerrar )")
        subtitle.set_name("subtitle")
        subtitle.set_halign(Gtk.Align.CENTER)
        root.pack_start(subtitle, False, False, 0)

        # Divisor
        sep = Gtk.Box()
        sep.set_name("divider")
        sep.set_size_request(-1, 1)
        root.pack_start(sep, False, False, 0)

        # ── Columnas ──────────────────────────────────────────────────────────
        cols_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL,
                           spacing=0, homogeneous=True)
        cols_box.set_name("columns")
        root.pack_start(cols_box, True, True, 0)

        for col_data in COLUMNS:
            col = self._build_column(col_data)
            cols_box.pack_start(col, True, True, 0)

    def _build_column(self, sections):
        col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        col.get_style_context().add_class("col")

        for sec in sections:
            # Header con color de fondo
            header = Gtk.Label(label=sec["title"].upper())
            header.get_style_context().add_class("sec-header")
            header.set_halign(Gtk.Align.START)

            # Color inline vía markup (GTK3 no permite background en label directo,
            # lo envolvemos en un EventBox coloreado)
            ebox = Gtk.EventBox()
            ebox.get_style_context().add_class("sec-header")
            # Pintar fondo via override_background_color
            rgba = Gdk.RGBA()
            rgba.parse(sec["color"])
            ebox.override_background_color(Gtk.StateFlags.NORMAL, rgba)

            text_rgba = Gdk.RGBA()
            text_rgba.parse(sec["text"])

            lbl = Gtk.Label(label=sec["title"].upper())
            lbl.get_style_context().add_class("sec-header")
            lbl.set_halign(Gtk.Align.START)
            lbl.override_color(Gtk.StateFlags.NORMAL, text_rgba)
            ebox.add(lbl)
            col.pack_start(ebox, False, False, 0)

            # Filas de keybinds
            for action, key in sec["binds"]:
                row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)

                act_lbl = Gtk.Label(label=action.upper())
                act_lbl.get_style_context().add_class("bind-action")
                act_lbl.set_halign(Gtk.Align.START)
                act_lbl.set_xalign(0)

                key_lbl = Gtk.Label(label=key)
                key_lbl.get_style_context().add_class("bind-key")
                key_lbl.set_halign(Gtk.Align.END)
                key_lbl.set_xalign(1)

                row.pack_start(act_lbl, True, True, 0)
                row.pack_start(key_lbl, False, False, 0)
                col.pack_start(row, False, False, 0)

        return col


if __name__ == "__main__":
    CheatSheet()
    Gtk.main()
