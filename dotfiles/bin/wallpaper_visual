#!/bin/bash
# wallpaper_visual: Selector visual de wallpapers para BLACK-ICE
# Soporta: .png .jpg .jpeg .webp — escaneo recursivo en subdirectorios
# BLACK-ICE ARCH | P4nx0z

# Detectar directorio de wallpapers
if command -v xdg-user-dir &>/dev/null; then
    PICTURES_DIR=$(xdg-user-dir PICTURES)
    [ -z "$PICTURES_DIR" ] && PICTURES_DIR="$HOME/Pictures"
else
    PICTURES_DIR="$HOME/Pictures"
fi

WALL_DIR="$PICTURES_DIR/wallpapers"
CACHE_FILE="$HOME/.cache/current_wallpaper"

if [ ! -d "$WALL_DIR" ]; then
    notify-send "Wallpaper" "No se encontró $WALL_DIR" --urgency=critical
    exit 1
fi

# Buscar recursivamente: .png .jpg .jpeg .webp .mp4 (incluye subdirs gh0stzk, etc.)
mapfile -t walls < <(find "$WALL_DIR" -type f \
    \( -iname "*.png" -o -iname "*.jpg" -o -iname "*.jpeg" \
       -o -iname "*.webp" -o -iname "*.mp4" \) 2>/dev/null | sort)

if [ ${#walls[@]} -eq 0 ]; then
    notify-send "Wallpaper" "No hay wallpapers en $WALL_DIR" --urgency=critical
    exit 1
fi

# Generar lista con ruta relativa + marcar el activo
CURRENT=$(cat "$CACHE_FILE" 2>/dev/null)
mapfile -t display_list < <(
    for w in "${walls[@]}"; do
        rel="${w#$WALL_DIR/}"
        if [ "$w" = "$CURRENT" ]; then
            echo "★ $rel"
        else
            echo "  $rel"
        fi
    done
)

# Selector wofi con ancho suficiente para rutas largas
SELECTION=$(printf '%s\n' "${display_list[@]}" | \
    wofi --dmenu \
         --prompt "󰋩  Wallpaper:" \
         --width 500 \
         --height 400 \
         --cache-file /dev/null \
         --insensitive \
         --no-actions)

[ -z "$SELECTION" ] && exit 0

# Reconstruir ruta completa (quitar prefijo de estado ★/espacio)
rel_path="${SELECTION#★ }"
rel_path="${rel_path#  }"
FULL_PATH="$WALL_DIR/$rel_path"

if [ ! -f "$FULL_PATH" ]; then
    notify-send "Wallpaper" "Archivo no encontrado: $rel_path" --urgency=critical
    exit 1
fi

echo "$FULL_PATH" > "$CACHE_FILE"

# Aplicar según tipo
if [[ "$FULL_PATH" == *.mp4 ]]; then
    pkill awww-daemon 2>/dev/null
    pkill mpvpaper 2>/dev/null
    sleep 0.3
    mpvpaper -o "no-audio --loop" "*" "$FULL_PATH" &>/dev/null &
else
    pkill mpvpaper 2>/dev/null
    if ! pgrep -x "awww-daemon" > /dev/null; then
        awww-daemon &
        sleep 0.5
    fi
    awww img "$FULL_PATH" --transition-type grow --transition-duration 1
fi

notify-send "BLACK-ICE" "Fondo: $(basename "$FULL_PATH")" --urgency=low
